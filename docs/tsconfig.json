{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@docs/*": [
        "*"
      ],
      "@docs/_shared/apis/*": [
        "_shared/apis/*"
      ],
      "@docs/_shared/components/*": [
        "_shared/components/*"
      ],
      "@docs/_shared/hooks": [
        "_shared/hooks/index.ts"
      ],
      "@docs/_shared/hooks/*": [
        "_shared/hooks/*"
      ]
    },
    "types": [
      "vite/client",
      "element-plus/global",
      "../packages/types/global.d.ts",
      "gi-component/packages/components.d.ts"
    ]
  },
  "include": [
    "./**/*.ts",
    "./**/*.vue",
    "./**/*.tsx",
    ".vitepress/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}