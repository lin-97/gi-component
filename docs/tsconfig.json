{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@docs/*": [
        "./*"
      ]
    },
    "types": [
      "vite/client",
      "element-plus/global",
      "../packages/types/config.d.ts",
      "gi-component/global"
    ]
  },
  "include": [
    "./**/*.ts",
    "./**/*.vue",
    "./**/*.tsx",
    ".vitepress/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}